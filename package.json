{
    "name": "reporter-liquid-preview",
    "displayName": "Reporter Liquid Preview",
    "description": "Live preview for Reporter Liquid templates",
    "version": "0.9.0",
    "publisher": "DGBooth",
    "engines": {
        "vscode": "^1.32.0"
    },
    "icon": "icon.png",
    "repository": {
        "type": "git",
        "url": "https://github.com/DGBooth/vscode-reporter-liquid-preview"
    },
    "galleryBanner": {
        "color": "#0F6378",
        "theme": "dark"
    },
    "categories": [
        "Other"
    ],
    "keywords": [
        "Reporter",
        "Liquid",
        "Template",
        "Live Preview"
    ],
    "activationEvents": [
        "onCommand:reporterLiquidPreview.preview",
        "onCommand:reporterLiquidPreview.htmlPreview",
        "onCommand:reporterLiquidPreview.fullHtmlPreview"
    ],
    "main": "./extension.js",
    "contributes": {
        "languages": [
            {
                "id": "liquid",
                "extensions": [
                    ".liquid"
                ]
            }
        ],
        "commands": [
            {
                "command": "reporterLiquidPreview.preview",
                "title": "Reporter Liquid: Open Preview to the Side"
            },
            {
                "command": "reporterLiquidPreview.htmlPreview",
                "title": "Reporter Liquid: Open HTML Preview to the Side"
            },
            {
                "command": "reporterLiquidPreview.fullHtmlPreview",
                "title": "Reporter Liquid: Open Full HTML Preview to the Side"
            }
        ],
        "keybindings": [
            {
                "command": "reporterLiquidPreview.preview",
                "key": "ctrl+k v",
                "when": "editorLangId == liquid"
            },
            {
                "command": "reporterLiquidPreview.htmlPreview",
                "key": "ctrl+k h",
                "when": "editorLangId == liquid"
            },
            {
                "command": "reporterLiquidPreview.fullHtmlPreview",
                "key": "ctrl+k f",
                "when": "editorLangId == liquid"
            }
        ]
    },
    "scripts": {},
    "devDependencies": {
        "@types/vscode": "^1.32.0"
    },
    "dependencies": {
        "liquidjs": "^8.4.1"
    }
}
